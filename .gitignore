# taller_angular — monorepo (Angular frontend + Express backend)

# Dependencias
node_modules/

# Variables de entorno (URI MongoDB, secrets)
.env
.env.*
!.env.example

# Backend — mantener la carpeta upload/articles en el repo; ignorar solo el contenido (imágenes)
backend/upload/articles/*
!backend/upload/articles/.gitkeep

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Frontend — compilado y caché de Angular
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out
frontend/.angular/cache/
frontend/coverage/
frontend/connect.lock
frontend/libpeerconnection.log
frontend/testem.log
frontend/typings/
frontend/__screenshots__/

# Testing / cobertura (cualquier paquete)
coverage/
*.lcov
.nyc_output/

# IDEs
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

